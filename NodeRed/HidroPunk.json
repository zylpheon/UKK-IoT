    {
        "id": "7f1d4c563927d079",
        "type": "function",
        "z": "242589dbbe1cdf98",
        "name": "Format Log Perintah",
        "func": "let raw = msg.payload;\nlet cmd = '';\ntry {\n  let obj = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  cmd = obj.command || JSON.stringify(obj);\n} catch(e) {\n  cmd = String(raw);\n}\nconst ts = new Date().toLocaleTimeString('id-ID', {timeZone:'Asia/Jakarta'});\nmsg.payload = '[' + ts + ' WIB] → ' + cmd;\nreturn msg;",
