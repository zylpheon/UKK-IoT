    {
        "id": "ff3643287c7b17df",
        "type": "function",
        "z": "242589dbbe1cdf98",
        "name": "Split Sensor Data",
        "func": "const p = msg.payload;\nconst suhu       = parseFloat(p.suhu       || 0);\nconst kelembaban = parseFloat(p.kelembaban  || 0);\nconst tinggi     = parseFloat(p.tinggi_air  || 0);\nconst status     = (p.status || 'UNKNOWN').toUpperCase();\nconst pompa      = p.pompa === true || p.pompa === 'true' || parseInt(p.pompa) === 1;\nconst mode       = p.mode || 'AUTO';\n\n// Simpan ke flow context\nflow.set('last_sensor', { suhu, kelembaban, tinggi, status, pompa, mode });\n\n// Label status tinggi air (jarak sensor→permukaan)\nlet labelAir = 'SIAGA ⚠️';\nif (tinggi <= 5)  labelAir = 'NORMAL ✅ (Penuh)';\nif (tinggi >= 20) labelAir = 'DARURAT 🚨 (Kosong)';\n\nreturn [\n  { payload: suhu },\n  { payload: kelembaban },\n  { payload: tinggi },\n  { payload: status + ' | Air: ' + labelAir },\n  { payload: pompa ? 'ON 🟢' : 'OFF 🔴' },\n  { payload: mode },\n  { payload: suhu,       topic: 'Suhu (°C)' },\n  { payload: kelembaban, topic: 'Kelembaban (%)' },\n  { payload: tinggi,     topic: 'Tinggi Air (cm)' }\n];",
        "outputs": 9,
        "noerr": 0,
        "x": 600,
        "y": 140,
